# KSR Auto's — Environment variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` to git.

# ─── Site ───────────────────────────────────────────────────────────────
# Used for canonical URLs, sitemap, JSON-LD, Open Graph.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ───────────────────────────────────────────────────────────
# Optional in development — when these are empty the app runs in seed
# mode using the bundled in-memory data set. Required for production.
#
# Get these from the Supabase dashboard:
#   Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-SIDE ONLY. Never expose this to the browser.
# Used for trusted writes (admin CRUD, anonymous inquiry inserts).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin ──────────────────────────────────────────────────────────────
# Demo password used when Supabase is NOT configured.
# Remove this in production (Supabase Auth replaces it).
ADMIN_PASSWORD=ksr-demo-2026

# ─── AI Chatbot ─────────────────────────────────────────────────────────
# Optional. When empty the chatbot uses deterministic rule-based replies
# grounded in the FAQ + current inventory.
DEEPSEEK_API_KEY=

# ─── Future: email notifications ────────────────────────────────────────
# Wire up Resend, SendGrid, etc. here when inquiries should be emailed.
# RESEND_API_KEY=
# INQUIRY_NOTIFICATION_TO=ksrautos@hotmail.com
